# ─── Required — Postiz core ───
# Generate with: openssl rand -hex 32
POSTIZ_JWT_SECRET=

# Postgres password for the bundled self-hosted postgres container.
# Generate with: openssl rand -hex 24
POSTIZ_DB_PASSWORD=

# Whether to disable public registration on the Postiz UI. Default "true":
# keeps your instance locked down. Flip to "false" only while creating the
# first admin account, then flip back. Leaving "false" on a publicly reachable
# instance lets anyone on the internet register and obtain API access.
POSTIZ_DISABLE_REGISTRATION=true

# ─── X / Twitter Developer App ───
# developer.x.com → Native App → Read+Write
# Callback URL: http://localhost:5000/integrations/social/x
X_API_KEY=
X_API_SECRET=

# ─── TikTok Content Posting API ───
# developers.tiktok.com → Create App → Request production
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── Meta / Instagram (Business account required) ───
# developers.facebook.com → Create App → Business → Instagram Graph API
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ─── YouTube (optional, we use YouTubeCLI instead) ───
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
