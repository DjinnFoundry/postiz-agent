  --font-body:    'Patrick Hand', sans-serif;
  --font-folio:   'Patrick Hand', sans-serif;
  --title-px: 150px;
  --body-px: 52px;
}
html, body { width: 1080px; height: 1920px; overflow: hidden; background: var(--bg); font-family: var(--font-body); color: var(--ink); }
#root { position: relative; width: 1080px; height: 1920px; }

.bg {
  position: absolute; inset: 0;
