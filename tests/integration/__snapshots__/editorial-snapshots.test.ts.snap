  tl.set("#page-0 [data-word='0']", { color: "#F0E2C8" }, 2.300);
  tl.set("#page-0 [data-word='0']", { className: "-=active" }, 2.300);
  tl.set("#page-0 [data-word='1']", { color: "#E8A93B" }, 2.300);
  tl.set("#page-0 [data-word='1']", { className: "+=active" }, 2.300);
  tl.set("#page-0 [data-word='1']", { color: "#F0E2C8" }, 2.450);
  tl.set("#page-0 [data-word='1']", { className: "-=active" }, 2.450);
  tl.set("#page-0 [data-word='2']", { color: "#E8A93B" }, 2.450);
