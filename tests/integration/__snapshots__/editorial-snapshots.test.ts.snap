  background: rgba(0, 0, 0, 0.35);
  border: 1px solid var(--accent);
  border-radius: 4px;
  padding: 8px 14px;
  font-size: 20px;
}
.part-ribbon-epic {
  font-family: var(--font-display);
  letter-spacing: 10px;
  text-transform: uppercase;
