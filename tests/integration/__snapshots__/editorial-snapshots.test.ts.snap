  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
:root {
  --bg: #EDE4FB;
  --ink: #2E1B5C;
  --accent: #6A4EB3;
  --muted: #675A94;
  --highlight: #FFD6E8;
