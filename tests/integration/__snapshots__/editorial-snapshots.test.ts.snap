    </div>

    <div class="clip end-card end-card-rose" data-start="4.000" data-duration="1.500" data-track-index="3"><span class="end-card-text">con cariño</span></div>
  </div>

  <script>
    const tl = gsap.timeline({ paused: true });
    tl.fromTo(".intro", { opacity: 1 }, { opacity: 0, duration: 0.3 }, 1.70);

