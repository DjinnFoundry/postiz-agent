}

.drop-cap {
  position: relative;
  float: left; display: block;
  font-family: var(--font-display); font-weight: 900;
  font-size: 300px; line-height: 0.85;
  background-image: linear-gradient(135deg, var(--accent) 0%, var(--highlight) 55%, var(--accent) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  text-shadow: 0 2px 0 rgba(0, 0, 0, 0.18), 0 0 1px rgba(255, 255, 255, 0.25);
  margin: 0.05em 0.12em 0 0;
  padding: 0.08em 0.12em; border: 4px double var(--accent); border-radius: 12px;
  z-index: 0;
}
.drop-cap::before {
  content: "";
  position: absolute;
  inset: -0.18em;
