# ─── Postiz (self-hosted) ───
POSTIZ_API_URL=http://localhost:5000/public/v1
POSTIZ_API_KEY=

# ─── X/Twitter Developer App ───
# Create at developer.x.com → Native App → Read+Write
# Callback: http://localhost:5000/integrations/social/x
X_API_KEY=
X_API_SECRET=

# ─── TikTok ───
# Register at developers.tiktok.com, requires production review
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── Instagram (Meta App) ───
# Business/Creator account required
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ─── AudioKids data source ───
AUDIOKIDS_OUTPUT_DIR=/path/to/audiokids/output
AUDIOKIDS_API_URL=
AUDIOKIDS_API_KEY=

# ─── YouTube (delegated to YouTubeCLI) ───
YOUTUBECLI_PATH=/path/to/youtubecli

# ─── Spotify RSS hosting ───
SPOTIFY_RSS_R2_BUCKET=audiokids-podcast
SPOTIFY_RSS_PUBLIC_URL=https://podcast.audiokids.org/feed.xml
