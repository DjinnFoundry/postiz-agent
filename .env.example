# ─── Postiz (self-hosted) ───
POSTIZ_API_URL=http://localhost:5000/public/v1
POSTIZ_API_KEY=

# ─── X/Twitter Developer App ───
# Create at developer.x.com → Native App → Read+Write
# Callback: http://localhost:5000/integrations/social/x
X_API_KEY=
X_API_SECRET=

# ─── TikTok ───
# Register at developers.tiktok.com, requires production review
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ─── Instagram (Meta App) ───
# Business/Creator account required
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ─── Content data source ───
# Directory containing slug.mp3 + slug.json + optional slug-cover.png.
CONTENT_OUTPUT_DIR=/path/to/content/output
CONTENT_BRAND=Postiz Agent
CONTENT_DEFAULT_LOCALE=es-ES

# ─── YouTube (delegated to YouTubeCLI) ───
YOUTUBECLI_PATH=/path/to/youtubecli

# ─── Spotify RSS hosting ───
SPOTIFY_RSS_R2_BUCKET=postiz-agent-podcast
SPOTIFY_RSS_PUBLIC_URL=https://podcast.example.com/feed.xml
# Comma-separated list of slugs to exclude from the RSS feed (drafts, private, etc.)
SPOTIFY_RSS_EXCLUDE_SLUGS=

# ─── Alerts ───
# Fire-and-forget webhook POST when a platform publish fails after retries.
# Payload: { slug, platform, error, attempts, timestamp }. 5s timeout; silent on error.
ALERT_WEBHOOK_URL=
